# R36S Configuration
# Ignore config.mk file which contains user-specific settings
# Settings in the template include the IP Address for SSH
# This is used to deploy builds to the device
# Keep config/ directory which contains config.mk.template file
# config/config.mk is generated by make
config/config.mk
config.mk
generated/config.mk

# Ignore Sound Manager sound_settings.ini file auto generated
# Changing a sound setting such as volume +/- creates or updates file
sound_settings.ini
/sound_settings.ini
assets/sound_settings.ini

# Ignore Achievements Manager data files 
# auto generated during game load
achievement_progress.data
/achievement_progress.data
data/achievement_progress.data

level_progress.data
/level_progress.data
data/level_progress.data